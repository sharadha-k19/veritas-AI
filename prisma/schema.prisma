// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Student {
  id           String   @id @default(cuid())
  fullName     String
  email        String   @unique
  password     String
  collegeName  String
  department   String
  studentId    String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  testResults  TestResult[]
  examKeys     ExamKey[]
}

model Admin {
  id               String   @id @default(cuid())
  fullName         String
  email            String   @unique
  password         String
  organizationName String
  role             String   // Admin / Instructor / Exam Controller
  department       String
  contactNumber    String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  tests            Test[]
}

model Test {
  id          String   @id @default(cuid())
  name        String
  type        String   // MCQ / Coding / Theory
  timeLimit   Int      // in minutes
  totalMarks  Int
  status      String   // Draft / Active / Completed
  examType    String   // Open-book / Closed-book
  allowedTools String? // JSON string of allowed tools
  questions   String   // JSON string of questions
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  admin       Admin    @relation(fields: [createdBy], references: [id])
  results     TestResult[]
  examKeys    ExamKey[]
}

model TestResult {
  id           String   @id @default(cuid())
  studentId    String
  testId       String
  marksScored  Int      @default(0)
  riskScore    Int      @default(0)
  flagStatus   String   @default("None") // None / Warning / Red Flag
  startedAt    DateTime?
  completedAt  DateTime?
  answers      String?  // JSON string of answers
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  student      Student  @relation(fields: [studentId], references: [id])
  test         Test     @relation(fields: [testId], references: [id])
  proctoringLogs ProctoringLog[]
}

model ProctoringLog {
  id            String   @id @default(cuid())
  testResultId  String
  timestamp     DateTime @default(now())
  eventType     String   // GazeMovement / ClipboardActivity / AppSwitch / DeviceConnection / etc.
  description   String
  riskPoints    Int      @default(0)
  severity      String   @default("Low") // Low / Medium / High
  
  testResult    TestResult @relation(fields: [testResultId], references: [id])
}

model ExamKey {
  id         String   @id @default(cuid())
  testId     String
  studentId  String
  key        String   @unique
  used       Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  
  test       Test     @relation(fields: [testId], references: [id])
  student    Student  @relation(fields: [studentId], references: [id])
}
